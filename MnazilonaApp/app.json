{
  "expo": {
    "name": "MnazilonaApp",
    "slug": "MnazilonaApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mnazilonaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.mnazilona.MnazilonaApp",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Required to connect to Mnazilona devices for setup and control.",
        "NSBluetoothPeripheralUsageDescription": "Required to set up and pair with your Mnazilona device via BLE.",
        "NSLocalNetworkUsageDescription": "Required to communicate with Mnazilona devices on your local network during setup.",
        "NSLocationWhenInUseUsageDescription": "Required to detect the WiFi network during device setup.",
        "NSBonjourServices": [
          "_mnazilona._tcp",
          "_http._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "192.168.4.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": false
            }
          }
        }
      },
      "entitlements": {
        "com.apple.developer.networking.HotspotConfiguration": true,
        "com.apple.developer.networking.wifi-info": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.CHANGE_NETWORK_STATE"
      ],
      "package": "com.mnazilona.MnazilonaApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "react-native-wifi-reborn",
      "expo-secure-store",
      "./plugins/withNetworkSecurityConfig"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
