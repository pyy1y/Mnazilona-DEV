# ==============================================================
# Manazel IoT Backend - Environment Variables
# ==============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================

# ── Server ──
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── JWT ──
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── MongoDB ──
MONGO_URI=mongodb://localhost:27017/MnazilonaProject

# ── Email (Gmail App Password or SMTP) ──
EMAIL_USER=
EMAIL_PASS=
# EMAIL_FROM=noreply@yourdomain.com   # Optional: override sender address
# APP_NAME=Manazel                     # Optional: override app name in emails

# ── MQTT Broker ──
MQTT_BROKER_URL=mqtt://your-broker-host
MQTT_BROKER_HOST=your-broker-host
MQTT_USERNAME=mqtt-user
MQTT_PASSWORD=

# ── MQTT Webhook Security ──
# Required in production. Set the same value in your MQTT broker webhook config.
MQTT_WEBHOOK_SECRET=

# ── CORS ──
# Mobile app origin (e.g., https://your-app-domain.com)
# Leave empty to reject all cross-origin requests
ALLOWED_ORIGIN=

# ── Rate Limiting (optional overrides) ──
# API_RATE_LIMIT=100
# OTP_SEND_LIMIT=5
# OTP_VERIFY_LIMIT=10
# LOGIN_RATE_LIMIT=10
# STRICT_RATE_LIMIT=5
# DEVICE_INQUIRY_LIMIT=30

# ── Verification Code (optional overrides) ──
# CODE_EXPIRY_MINUTES=5
# CODE_MAX_ATTEMPTS=5

# ── Device Timeout (optional overrides) ──
# HEARTBEAT_TIMEOUT_MS=120000
# DEVICE_CHECK_INTERVAL_MS=60000
